#!/bin/sh
# tigermemory pre-commit hook — blocks mojibake writes into markdown files.
# + inbox routing signature check (enforce mode: rejects unsigned inbox commits)
# Install with: git config core.hooksPath .githooks
#
# Bypass (human emergency only): git commit --no-verify

set -e
ROOT="$(git rev-parse --show-toplevel)"

PY=""
for cand in "py -3" python3 python; do
  if $cand -c "import sys" >/dev/null 2>&1; then
    PY="$cand"
    break
  fi
done
if [ -z "$PY" ]; then
  echo "tigermemory pre-commit: no working python found (tried py -3, python3, python)" >&2
  exit 1
fi

$PY "$ROOT/tools/tm_mojibake_guard.py"

# F2: cross-worktree drift guard.
# Prevents committing on top of a stale local HEAD when another worktree
# (D:\tigermemory vs ~/tigermemory) or MCP server has already pushed to origin.
# See inbox/2026-04-30-1349-claude-code-systems.md §F2 for context.
# Bypass: TM_SKIP_DRIFT_GUARD=1 (offline / local-only repo). --no-verify is human-only.
#
# 2026-05-03 relaxation: if the staged diff is ONLY new inbox/*.md files
# (all A, no M/D, no wiki/tools/etc), skip drift check. Inbox filenames are
# minute-timestamp-unique across agents/worktrees, so fast-forward push is
# guaranteed; drift cannot cause content conflicts. This unblocks parallel
# memory writes from Claw/mobile agents without forcing WSL to pre-pull.
staged_all=$(git diff --cached --name-status)
staged_non_inbox_add=$(echo "$staged_all" | awk '$1 != "A" || $2 !~ /^inbox\/[^/]+\.md$/' | grep -v '^$' || true)
if [ -n "$staged_all" ] && [ -z "$staged_non_inbox_add" ]; then
  TM_SKIP_DRIFT_GUARD=1
fi
if [ -z "${TM_SKIP_DRIFT_GUARD:-}" ]; then
  upstream=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || true)
  if [ -n "$upstream" ]; then
    # Quiet fetch with timeout; if offline, skip guard rather than block work.
    if git fetch --quiet --no-tags origin 2>/dev/null; then
      behind=$(git rev-list --count "HEAD..$upstream" 2>/dev/null || echo 0)
      if [ "$behind" -gt 0 ]; then
        echo "[tigermemory pre-commit] cross-worktree drift detected: HEAD is $behind commit(s) behind $upstream." >&2
        echo "  another worktree (D:/tigermemory <-> ~/tigermemory) or MCP server pushed to origin." >&2
        echo "  resolve: git pull --rebase origin master  (then retry commit)" >&2
        echo "  bypass:  TM_SKIP_DRIFT_GUARD=1 git commit ...   (offline / read-only mirror)" >&2
        echo "  --no-verify is human emergency only; do not use to skirt drift." >&2
        $PY "$ROOT/tools/tm_reject_log.py" append --guard drift --msg "HEAD behind $upstream by $behind commit(s)" 2>/dev/null || true
        exit 1
      fi
    fi
  fi
fi

# Inbox routing signature check
staged_inbox=$(git diff --cached --name-only --diff-filter=A | grep -E '^inbox/[^/]+\.md$' || true)
for f in $staged_inbox; do
  if ! grep -qE '^routed_by: (tigermemory|human-direct)$' "$ROOT/$f"; then
    echo "[tigermemory pre-commit] $f missing 'routed_by: tigermemory' frontmatter." >&2
    echo "  use: python tools/tm_io.py write-inbox ..." >&2
    echo "       or MCP write_memory / write_inbox tools" >&2
    echo "  direct git add inbox/*.md is forbidden." >&2
    $PY "$ROOT/tools/tm_reject_log.py" append --guard routed_by --file "$f" --msg "missing routed_by frontmatter" 2>/dev/null || true
    exit 1
  fi
done

# Dashboard static files: reject external CDN references.
# Mirrors dashboard-ui-v2-brief.md P1 goal: zero external CDN in dashboard.
# Only scans tools/static/ files (HTML/JS/CSS). [human] --no-verify bypasses.
staged_dashboard=$(git diff --cached --name-only | grep -E '^tools/static/.*\.(html|js|css)$' || true)
for f in $staged_dashboard; do
  if grep -qE 'cdn\.tailwindcss\.com|unpkg\.com|cdnjs\.cloudflare\.com' "$ROOT/$f"; then
    echo "[tigermemory pre-commit] external CDN detected in $f" >&2
    echo "  dashboard files must not reference external CDN (tailwindcss, unpkg, cdnjs)." >&2
    echo "  inline the styles/icons or use local static assets." >&2
    echo "  see: wiki/systems/dashboard-ui-v2-brief.md (去 CDN P1 target)" >&2
    $PY "$ROOT/tools/tm_reject_log.py" append --guard cdn --file "$f" --msg "external CDN in dashboard static file" 2>/dev/null || true
    exit 1
  fi
done

