#!/bin/sh
# tigermemory pre-push hook — lightweight package smoke checks.

set -e
ROOT="$(git rev-parse --show-toplevel)"
SMOKE_ROOT=""

cleanup() {
  if [ -n "$SMOKE_ROOT" ]; then
    git -C "$ROOT" worktree remove --force "$SMOKE_ROOT" >/dev/null 2>&1 || rm -rf "$SMOKE_ROOT"
  fi
}
trap cleanup EXIT

PY=""
for cand in "py -3" python3 python; do
  if $cand -c "import sys" >/dev/null 2>&1; then
    PY="$cand"
    break
  fi
done
if [ -z "$PY" ]; then
  echo "tigermemory pre-push: no working python found (tried py -3, python3, python)" >&2
  exit 1
fi

SMOKE_ROOT="$(mktemp -d "${TMPDIR:-/tmp}/tigermemory-pre-push.XXXXXX")"
git -C "$ROOT" worktree add --detach --quiet "$SMOKE_ROOT" HEAD

export PYTHONPATH="$SMOKE_ROOT/packages/tigermemory-publish/src${PYTHONPATH:+:$PYTHONPATH}"

if ! $PY -m tigermemory_publish --dry-run --json >/dev/null; then
  echo "[tigermemory pre-push] tigermemory_publish dry-run smoke failed" >&2
  exit 1
fi
