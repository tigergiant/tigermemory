#!/bin/sh
# tigermemory pre-push hook — lightweight package smoke checks.

set -e
ROOT="$(git rev-parse --show-toplevel)"

PY=""
for cand in "py -3" python3 python; do
  if $cand -c "import sys" >/dev/null 2>&1; then
    PY="$cand"
    break
  fi
done
if [ -z "$PY" ]; then
  echo "tigermemory pre-push: no working python found (tried py -3, python3, python)" >&2
  exit 1
fi

export PYTHONPATH="$ROOT/packages/tigermemory-publish/src${PYTHONPATH:+:$PYTHONPATH}"

if ! $PY -m tigermemory_publish --dry-run --json >/dev/null; then
  echo "[tigermemory pre-push] tigermemory_publish dry-run smoke failed" >&2
  exit 1
fi
