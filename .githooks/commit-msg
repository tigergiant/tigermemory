#!/bin/sh
# tigermemory commit-msg hook — enforces AGENTS.md rules via tm_io.py guard.
# Install with: git config core.hooksPath .githooks  (or run tools/install_hooks.sh)
#
# Bypass (human emergency only): git commit --no-verify

set -e
ROOT="$(git rev-parse --show-toplevel)"

# Find a working Python. On Windows, `python` / `python3` may be WindowsApps
# stubs that print nothing and exit non-zero — verify by actually running.
PY=""
for cand in "py -3" python3 python; do
  if $cand -c "import sys" >/dev/null 2>&1; then
    PY="$cand"
    break
  fi
done
if [ -z "$PY" ]; then
  echo "tigermemory hook: no working python found (tried py -3, python3, python)" >&2
  exit 1
fi

exec $PY "$ROOT/tools/tm_io.py" guard --commit-msg-file "$1"
