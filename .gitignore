# Asset source directory: keep large images local, but track lightweight
# index pages for GitHub-backed memory retrieval.
sources/assets/*
!sources/assets/index.md
*.tmp
.tmp/
.trash/
*.log
*.code-workspace
progress.md
# Real-time digest views: regenerated continuously by debounced timer;
# canonical commit owned by daily-lint cron (force-add).
inbox/daily/*.md
plans/
__pycache__/
*.pyc
*.egg-info/
deploy/openclaw-ce/node_modules/
deploy/openclaw-ce/dist/
deploy/openclaw-ce/*.tsbuildinfo

# 敏感个人数据 - 记账记录
data/expense_tracker/

# Local memory backend state (P4.1 local profile)
data/tigermemory/*.sqlite
data/tigermemory/*.sqlite-shm
data/tigermemory/*.sqlite-wal

# Top-level catch-all for any local npm experiments
node_modules/

# 敏感账单原始文件（仅保留 README，禁止入库账单内容）
data/expense_import/raw/**/*.pdf
data/expense_import/raw/**/*.csv
data/expense_import/raw/**/*.xlsx
data/expense_import/raw/**/*.xls

# expense_import 中间产物与备份（PII / 大体量，不入库）
data/expense_import/backups/
data/expense_import/staging/
data/expense_import/extracted/
data/expense_import/logs/
data/expense_import/reports/2026/audit_replay/*.sqlite
data/expense_import/reports/2026/audit_replay/**/*.sqlite
data/expense_import/reports/2026/audit_replay/40_shadow_workdir/

# Dashboard local state (preferences are proposed back to wiki/person via review)
data/dashboard/*.sqlite
data/dashboard/*.sqlite-shm
data/dashboard/*.sqlite-wal

# tools/tm_publish.py outward snapshot output (P2 stage2-2)
dist/

# Python package build artifacts (setuptools 'pip install -e .' produces
# packages/<name>/build/lib/* as a 1:1 copy of src/; not source of truth).
packages/*/build/
